# =====================================================================
#  BioMed Tools - Variables de entorno
#  Copia este archivo a ".env" y rellena los valores.
#      cp .env.example .env        (Linux/Mac)
#      Copy-Item .env.example .env (Windows PowerShell)
# =====================================================================

# ---------- Entorno ----------
# 'development' muestra detalles de error; usa 'production' al desplegar.
NODE_ENV=development

# ---------- Puertos expuestos en tu máquina ----------
BACKEND_PORT=4000
# Si el 8080 está ocupado en tu máquina (p.ej. por otro servicio), usa otro.
FRONTEND_PORT=8090
# Puerto del HOST para MySQL. Usa 3307 si ya tienes un MySQL local en 3306.
# (Dentro de Docker el backend siempre usa el 3306 interno.)
MYSQL_HOST_PORT=3307
QDRANT_PORT=6333

# ---------- Base de datos MySQL ----------
MYSQL_ROOT_PASSWORD=cambia_esta_clave_root
MYSQL_DATABASE=biomed
MYSQL_USER=biomed
MYSQL_PASSWORD=cambia_esta_clave
# MYSQL_HOST lo fija docker-compose (mysql). Para correr el backend FUERA de
# Docker, descomenta:
# MYSQL_HOST=localhost

# ---------- Almacenamiento de PDFs ----------
# local = disco (carpeta ./storage). Más adelante: s3 / minio / gcs.
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./storage

# ---------- Vector store (RAG) ----------
# QDRANT_URL lo fija docker-compose. Fuera de Docker: http://localhost:6333

# ---------- Asistente IA / RAG (Fase 4) ----------
# Proveedor: 'gemini' (free tier, recomendado) u 'openai' (DeepSeek/Groq/Ollama/OpenAI).
AI_PROVIDER=gemini

# --- Opción A: Google Gemini (gratis) ---
# Crea tu clave en https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Modelo de chat. Si recibes error 429 (cuota) con gemini-2.0-flash, usa
# gemini-2.5-flash (suele tener cuota libre disponible).
AI_CHAT_MODEL=gemini-2.5-flash
# Modelo de embeddings. Las claves nuevas (formato "AQ.") usan gemini-embedding-001;
# claves antiguas (formato "AIza") pueden usar text-embedding-004.
AI_EMBEDDING_MODEL=gemini-embedding-001
AI_EMBEDDING_DIM=768
# Grounding web (Google Search) en modo Asesor. Solo lo soporta Gemini.
AI_WEB_GROUNDING=true

# --- Opción B: compatible con OpenAI (DeepSeek/Groq/Ollama/OpenAI) ---
# Descomenta y ajusta si usas AI_PROVIDER=openai. Ejemplos de AI_BASE_URL:
#   DeepSeek: https://api.deepseek.com/v1   (no tiene embeddings -> usa Gemini/Ollama para embeddings)
#   Groq:     https://api.groq.com/openai/v1
#   Ollama:   http://host.docker.internal:11434/v1
# AI_BASE_URL=
# AI_API_KEY=

# Parámetros del RAG (opcionales).
RAG_COLLECTION=biomed_docs
RAG_CHUNK_SIZE=1500
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=5

# ---------- Autenticación (Fase 3) ----------
# Genera un secreto largo y aleatorio, p.ej.:  openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=8h

# Admin inicial: se crea automáticamente al arrancar si no existe ningún admin.
ADMIN_NOMBRE=Administrador
ADMIN_EMAIL=admin@biomedtools.local
ADMIN_PASSWORD=cambia_esta_clave_admin

# ---------- Frontend ----------
# URL pública del backend que usará el frontend al construirse.
VITE_API_URL=http://localhost:4000/api

# ---------- CORS ----------
CORS_ORIGIN=*
